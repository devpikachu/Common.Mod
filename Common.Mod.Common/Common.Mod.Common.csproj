      <ExcludeAssets>runtime</ExcludeAssets>
    </PackageReference>
    <PackageReference Include="System.Collections.Immutable" Version="9.0.9"/>
    <PackageReference Include="System.Text.Json" Version="9.0.9"/>
  </ItemGroup>

</Project>
