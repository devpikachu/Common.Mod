{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://git.omni.ms/vintage-story-mods/common-mod/raw/branch/main/schemas/config.schema.json",
  "title": "Config Specification",
  "description": "Config specification for code generation",
  "type": "object",
  "required": [
    "className",
    "classNamespace",
    "entries"
  ],
  "properties": {
    "className": {
      "type": "string",
      "description": "The name of the class",
      "minLength": 1,
      "pattern": "^[a-zA-Z]+[a-zA-Z0-9_]*$"
    },
    "classNamespace": {
      "type": "string",
      "description": "The namespace to generate the class in",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9_\\.]+$"
    },
    "description": {
      "type": [
        "string",
        "null"
      ],
      "description": "The description of the class",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "description": "The entries of the class",
      "minItems": 1,
      "items": {
        "$ref": "/vintage-story-mods/common-mod/raw/branch/main/schemas/entry.schema.json"
      }
    }
  }
}
