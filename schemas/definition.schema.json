{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://git.omni.ms/vintage-story-mods/common-mod/raw/branch/main/schemas/config.schema.json",
  "title": "Definition Specification",
  "description": "Definition specification for code generation",
  "type": "object",
  "required": [
    "rootConfigs"
  ],
  "properties": {
    "rootConfigs": {
      "type": "array",
      "description": "The list of root configs, i.e. those that'll be registered with IConfigSystem",
      "minItems": 1,
      "items": {
        "$ref": "/vintage-story-mods/common-mod/raw/branch/main/schemas/rootConfig.schema.json"
      }
    },
    "configs": {
      "type": "array",
      "description": "The list of configs, i.e. those that'll be nested within other configs",
      "minItems": 1,
      "items": {
        "$ref": "/vintage-story-mods/common-mod/raw/branch/main/schemas/config.schema.json"
      }
    },
    "enums": {
      "type": "array",
      "description": "The list of enums",
      "minItems": 1,
      "items": {
        "$ref": "/vintage-story-mods/common-mod/raw/branch/main/schemas/enum.schema.json"
      }
    }
  }
}
