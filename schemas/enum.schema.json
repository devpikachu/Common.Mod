{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://git.omni.ms/vintage-story-mods/common-mod/raw/branch/main/schemas/enum.schema.json",
  "title": "Enum Specification",
  "description": "Enum specification for code generation",
  "type": "object",
  "required": [
    "enumName",
    "enumNamespace",
    "values"
  ],
  "properties": {
    "enumName": {
      "type": "string",
      "description": "The name of the enum",
      "minLength": 1,
      "pattern": "^[a-zA-Z]+[a-zA-Z0-9_]*$"
    },
    "enumNamespace": {
      "type": "string",
      "description": "The namespace to generate the enum in",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9_\\.]+$"
    },
    "description": {
      "type": [
        "string",
        "null"
      ],
      "description": "The description of the enum",
      "minLength": 1
    },
    "values": {
      "type": "array",
      "description": "The values of the enum",
      "uniqueItems": true,
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
